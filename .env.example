# =============================================================================
# Artemis AI - Variaveis de ambiente (TEMPLATE)
# =============================================================================
# Copie para .env e preencha com seus valores reais.
# .env esta no .gitignore - NUNCA commitar com valores reais.
# =============================================================================

# IP publico da VM (ICE candidate WebRTC). Obtenha com: curl ifconfig.me
PUBLIC_IP=CHANGE_ME

# Dominio base onde voce apontou os subdominios
# Ex: artemis.example.com (entao perfis serao fabio.artemis.example.com)
DOMAIN_BASE=CHANGE_ME

# E-mail para Let's Encrypt (avisos de expiracao)
LE_EMAIL=admin@example.com

# -------- SENHAS DOS PERFIS --------
# Cada perfil tem dois niveis:
#   USER  = visualiza e interage (controle compartilhado)
#   ADMIN = controle total + configuracoes
# Gere senhas fortes (20+ chars) com:
#   python3 -c "import secrets, string; print(''.join(secrets.choice(string.ascii_letters+string.digits+'!@#%&*+=?') for _ in range(20)))"

PROFILE1_USER_PASS=CHANGE_ME
PROFILE1_ADMIN_PASS=CHANGE_ME

PROFILE2_USER_PASS=CHANGE_ME
PROFILE2_ADMIN_PASS=CHANGE_ME

PROFILE3_USER_PASS=CHANGE_ME
PROFILE3_ADMIN_PASS=CHANGE_ME

PROFILE4_USER_PASS=CHANGE_ME
PROFILE4_ADMIN_PASS=CHANGE_ME

# -------- TRAEFIK DASHBOARD --------
# Hash basic-auth: gere com:
#   sudo apt install apache2-utils
#   htpasswd -nbB admin SUASENHA
# IMPORTANTE: dobre os "$" -> "$2y$05..." vira "$$2y$$05..."
TRAEFIK_BASIC_AUTH=admin:$$2y$$05$$REPLACE_WITH_REAL_BCRYPT_HASH
